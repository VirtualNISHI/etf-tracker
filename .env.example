# Etherscan API (https://etherscan.io/myapikey で無料取得)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Discord Webhooks (チャットや公開リポに絶対貼らないこと)
DISCORD_WEBHOOK_DAILY=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_ALERT=https://discord.com/api/webhooks/xxx/zzz

# 動作モード
LOG_LEVEL=INFO
# DRY_RUN=true にするとDiscord/X送信をスキップ(ログのみ)
DRY_RUN=false

# X (Twitter) 投稿用 OAuth 1.0a User Context (任意)
# 4つすべて埋まれば投稿、ひとつでも空ならスキップ
# 取得元: https://developer.x.com/en/portal/dashboard → アプリ → "Keys and tokens"
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
