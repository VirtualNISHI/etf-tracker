# Etherscan API (https://etherscan.io/myapikey で無料取得)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Discord Webhooks (チャットや公開リポに絶対貼らないこと)
DISCORD_WEBHOOK_DAILY=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_ALERT=https://discord.com/api/webhooks/xxx/zzz

# 動作モード
LOG_LEVEL=INFO
# DRY_RUN=true にするとDiscord/X送信をスキップ(ログのみ)
DRY_RUN=false

# X (Twitter) 投稿用 OAuth 1.0a User Context (任意)
# 4つすべて埋まれば投稿、ひとつでも空ならスキップ
# 取得元: https://developer.x.com/en/portal/dashboard → アプリ → "Keys and tokens"
X_API_KEY=
X_API_KEY_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# リアルタイム大口アラートの X 自動投稿スイッチ(安全弁)。
# 既定 false = 認証情報があっても alert は data/alert_x_preview.png を出すだけで実投稿しない。
# 画像とキャプションを確認し、投稿してよいと判断したら true にする。
# (定時 daily レポートの投稿は従来どおり X 認証情報の有無のみで制御)
X_ALERT_ENABLED=false

# --- Japanese translation chain (shared jp_translator module) ---
# 順序: Gemini → OpenAI → Grok → DeepL (fallback chain)。
# 最低 1 つ設定すれば動く (失敗時のみ次へ)。
#  1) Gemini  : https://aistudio.google.com/apikey  (free 1500 RPD)
#  2) OpenAI  : https://platform.openai.com/api-keys (paid)。GPT-4o/GPT-5 系
#  3) Grok    : https://console.x.ai                (paid)。GROK_API_KEY も別名で可
#  4) DeepL   : https://www.deepl.com/pro-api       (free 500K char/月。:fx で終わる)
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
DEEPL_API_KEY=
# 任意: モデル上書き (default は thinking 非搭載の lite モデル)
#JP_TRANSLATOR_GEMINI_MODEL=gemini-2.5-flash-lite
#JP_TRANSLATOR_OPENAI_MODEL=gpt-4o-mini
#JP_TRANSLATOR_GROK_MODEL=grok-2-1212
