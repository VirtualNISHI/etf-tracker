# Etherscan API (https://etherscan.io/myapikey で無料取得)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Discord Webhooks (チャットや公開リポに絶対貼らないこと)
DISCORD_WEBHOOK_DAILY=https://discord.com/api/webhooks/xxx/yyy
DISCORD_WEBHOOK_ALERT=https://discord.com/api/webhooks/xxx/zzz

# 動作モード
LOG_LEVEL=INFO
# DRY_RUN=true にするとDiscord送信をスキップ(ログのみ)
DRY_RUN=false
